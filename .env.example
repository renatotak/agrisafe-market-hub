# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (for admin/cron operations)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron secret (for securing cron API routes in production)
# CRON_SECRET=your-cron-secret

# Google Maps
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Embrapa AgroAPI (AGROFIT, Bioinsumos, ClimAPI, AgroTermos, SmartSolos)
# Get keys at: https://www.agroapi.cnptia.embrapa.br/store/
# AGROAPI_CONSUMER_KEY=your-consumer-key
# AGROAPI_CONSUMER_SECRET=your-consumer-secret

# Google Custom Search (100 free queries/day for company web research)
# Create at: https://programmablesearchengine.google.com/
# API key at: https://console.cloud.google.com/apis/credentials
# GOOGLE_CUSTOM_SEARCH_KEY=your-api-key
# GOOGLE_CUSTOM_SEARCH_CX=your-search-engine-id

# OpenAI (optional — for AI summaries in web research)
# OPENAI_API_KEY=your-openai-key
