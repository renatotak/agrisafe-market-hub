{
  "manifest_version": 3,
  "name": "AgriSafe Reading Room",
  "short_name": "Reading Room",
  "version": "3.0.0",
  "description": "One-click save with automatic sync to the AgriSafe Market Hub via /api/reading-room/ingest.",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "https://*.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [{
    "resources": ["library.html"],
    "matches": ["<all_urls>"]
  }]
}
